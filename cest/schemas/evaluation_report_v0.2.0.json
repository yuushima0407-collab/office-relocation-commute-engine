{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cest://schemas/evaluation_report/v0.2.0",
  "title": "CEST Evaluation Report v0.2.0",
  "type": "object",
  "required": [
    "version",
    "generated_at",
    "inputs",
    "results",
    "by_num_offices",
    "num_offices_summary",
    "ranking",
    "explain_pack",
    "sensitivity",
    "notices"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.2.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "baseline_scenario_id": { "type": ["string", "null"] },
    "inputs": {
      "type": "object",
      "required": ["home_station_distribution", "office_candidates", "policy_as_is", "settings"],
      "properties": {
        "home_station_distribution": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["station_id", "count"],
            "properties": {
              "station_id": { "type": "string" },
              "count": { "type": "integer", "minimum": 1 },
              "segment": { "type": ["string", "null"] },
              "group": { "type": ["string", "null"] },
              "office_days_per_week_override": {
                "type": ["number", "null"],
                "minimum": 0,
                "maximum": 5
              }
            },
            "additionalProperties": false
          }
        },
        "office_candidates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 10,
          "items": {
            "type": "object",
            "required": ["office_id", "name", "nearest_station_id", "last_mile_minutes"],
            "properties": {
              "office_id": { "type": "string" },
              "name": { "type": "string" },
              "nearest_station_id": { "type": "string" },
              "last_mile_minutes": {
                "type": "number",
                "minimum": 0,
                "maximum": 60
              },
              "lat": { "type": ["number", "null"] },
              "lon": { "type": ["number", "null"] },
              "rent_jpy_month": { "type": ["integer", "null"], "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "policy_as_is": {
          "type": "object",
          "required": ["office_days_per_week"],
          "properties": {
            "office_days_per_week": { "type": "number", "minimum": 0, "maximum": 5 }
          },
          "additionalProperties": false
        },
        "settings": {
          "type": "object",
          "required": [
            "baseline_office_id",
            "thresholds_trip_minutes",
            "bench_trip_p95_minutes",
            "bench_rent_jpy_month",
            "robust_flip_rate_threshold",
            "routing"
          ],
          "properties": {
            "baseline_office_id": { "type": ["string", "null"] },
            "thresholds_trip_minutes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "number", "minimum": 0 }
            },
            "percentiles": {
              "type": "array",
              "items": { "type": "integer" }
            },
            "ranking_weights": {
              "type": ["object", "null"],
              "properties": {
                "access": { "type": "number", "minimum": 0, "maximum": 1 },
                "financial": { "type": "number", "minimum": 0, "maximum": 1 },
                "hazard": { "type": "number", "minimum": 0, "maximum": 1 }
              },
              "required": ["access", "financial", "hazard"],
              "additionalProperties": false
            },
            "bench_trip_p95_minutes": { "type": "number", "minimum": 1 },
            "bench_rent_jpy_month": { "type": "number", "minimum": 1 },
            "robust_flip_rate_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "num_offices": {
              "type": "array",
              "items": { "type": "integer", "minimum": 1 }
            },
            "fixed_offices": {
              "type": "array",
              "items": { "type": "string" }
            },
            "fixed_assignment": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "budget_total_rent_jpy_month": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "routing": {
              "type": "object",
              "required": ["graph_id", "transfer_penalty_minutes"],
              "properties": {
                "graph_id": { "type": ["string", "null"] },
                "transfer_penalty_minutes": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 60
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "results": { "$ref": "evaluation_report_v0.1.2.json#/properties/results" },
    "by_num_offices": {
      "type": "object",
      "patternProperties": {
        "^[0-9]+$": {
          "type": "object",
          "required": ["combinations"],
          "properties": {
            "combinations": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "combination_id",
                  "selected_offices",
                  "total_rent_jpy_month",
                  "assignment",
                  "per_office_results",
                  "aggregate_kpis"
                ],
                "properties": {
                  "combination_id": { "type": "string" },
                  "selected_offices": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "total_rent_jpy_month": { "type": "integer", "minimum": 0 },
                  "assignment": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["group", "assigned_office_id", "population"],
                      "properties": {
                        "group": { "type": "string" },
                        "assigned_office_id": { "type": "string" },
                        "population": { "type": "integer", "minimum": 0 }
                      },
                      "additionalProperties": false
                    }
                  },
                  "per_office_results": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "office_id",
                        "assigned_population",
                        "kpis",
                        "station_breakdown"
                      ],
                      "properties": {
                        "office_id": { "type": "string" },
                        "assigned_population": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "kpis": {
                          "$ref": "evaluation_report_v0.1.2.json#/properties/results/items/properties/kpis"
                        },
                        "station_breakdown": {
                          "$ref": "evaluation_report_v0.1.2.json#/properties/results/items/properties/station_breakdown"
                        },
                        "hazard": {
                          "type": "object",
                          "properties": {
                            "score_0_100": {
                              "type": ["number", "null"],
                              "minimum": 0,
                              "maximum": 100
                            },
                            "flood_depth_m": { "type": ["number", "null"] },
                            "seismic_rank": { "type": ["number", "null"] }
                          },
                          "additionalProperties": false
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "aggregate_kpis": {
                    "type": "object",
                    "properties": {
                      "trip_p95": { "type": ["number", "null"], "minimum": 0 }
                    },
                    "additionalProperties": true
                  },
                  "axis_scores": {
                    "type": "object",
                    "properties": {
                      "access": { "type": ["number", "null"] },
                      "financial": { "type": ["number", "null"] },
                      "hazard": { "type": ["number", "null"] }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "num_offices_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["num_offices", "top_combination_id", "trip_p95", "total_rent"],
        "properties": {
          "num_offices": { "type": "integer" },
          "top_combination_id": { "type": "string" },
          "trip_p95": { "type": ["number", "null"], "minimum": 0 },
          "total_rent": { "type": "integer", "minimum": 0 },
          "hazard_avg": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "vs_previous": {
            "type": ["object", "null"],
            "properties": {
              "trip_p95_change_pct": { "type": "number" },
              "rent_change_pct": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "ranking": {
      "type": ["object", "null"]
    },
    "explain_pack": {
      "$ref": "evaluation_report_v0.1.2.json#/properties/explain_pack"
    },
    "sensitivity": {
      "$ref": "evaluation_report_v0.1.2.json#/properties/sensitivity"
    },
    "notices": {
      "$ref": "evaluation_report_v0.1.2.json#/properties/notices"
    }
  },
  "additionalProperties": false
}

